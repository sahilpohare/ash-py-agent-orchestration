# Database
DATABASE_URL=postgresql://app:app@localhost:5432/ironbridge

# Restate ingress
RESTATE_URL=http://localhost:8080

# Pusher (real-time delivery to browser clients)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=eu

# LLM provider (used by WeatherAgent and StreamingWeatherAgent)
CEREBRAS_API_KEY=your_cerebras_api_key
